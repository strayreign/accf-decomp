# -----------------------------------------------------------------------
# Tom Hook system — AI-driven decomp loop; requires paid API keys,
# local model setup, and proprietary tool paths.  Not for public repo.
# -----------------------------------------------------------------------
tools/autopilot.py
tools/tom_hook.py
tools/decomp_loop.py
tools/self_healer.py
# Backup files written by the session patcher
tools/*.bak

# -----------------------------------------------------------------------
# Windows scripts and launchers — contain machine-local paths + API keys
# -----------------------------------------------------------------------
*.ps1
*.bat

# -----------------------------------------------------------------------
# IDA Pro integration — requires commercial IDA Pro licence
# -----------------------------------------------------------------------
tools/ida_server.py
tools/dol_loader.py
ida_scripts/

# -----------------------------------------------------------------------
# Paid-API runtime state
# -----------------------------------------------------------------------
tools/claude_spend.json

# -----------------------------------------------------------------------
# Generated symbol / analysis artefacts
# -----------------------------------------------------------------------
tools/symbol_report.txt

