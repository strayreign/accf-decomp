# -----------------------------------------------------------------------
# Licensed Nintendo data — ROM images, DOLs, RELs, WADs, SDK binaries
# These files contain Nintendo intellectual property and must never be
# committed.  The .dol / .rel patterns above already cover build outputs;
# the patterns below cover source / ROM material.
# -----------------------------------------------------------------------
*.iso
*.wbfs
*.wia
*.ciso
*.gcm
*.wad
*.tmd
*.ticket
*.app
# Raw ROM dumps or extracted disc images
*.img
# Official Nintendo / CodeWarrior SDK binaries and archives
*.a
*.lib
mwcceppc*
mwldeppc*
# SDK source trees that may have been extracted locally
data/sdk_sources/

# -----------------------------------------------------------------------
# Scraped / auto-downloaded third-party symbol data and SDK headers
# These are fetched at runtime by resource_scraper.py and must not be
# committed — they are either copyrighted or under restrictive licences.
# -----------------------------------------------------------------------
data/scraped/
data/scraped/**

# -----------------------------------------------------------------------
# Generated hint / context files derived from Nintendo / SDK data
# (these embed symbol names or code patterns extracted from game files)
# -----------------------------------------------------------------------
data/sdk_signatures.json
data/ghidra_symbols.json
data/nl_symbols.json
data/bbq_symbols.json
data/ac_class_context.txt
data/dwc_context.txt
data/symbol_hints.json
data/strategy_notes.txt

# -----------------------------------------------------------------------
# Scraper and SDK-ingestion tooling
# These scripts reference external proprietary sources; keeping them out
# of the public repo avoids drawing attention to what is being scraped.
# -----------------------------------------------------------------------
tools/resource_scraper.py
tools/ingest_sdk_sources.py
tools/rebuild_sdk_and_hints.sh

# -----------------------------------------------------------------------
# AI analysis / helper scripts — require local models or API keys
# -----------------------------------------------------------------------
tools/compiler_hints.py
tools/compiler_hints_debug.py
tools/decomp_loop_compiler_hooks.py
tools/symbol_hunter.py
tools/cross_game_symbols.py
tools/monitor.py
tools/gdb_probe.py
tools/batch_fix.py
tools/objdiff_wrapper.py
tools/test_objdiff_cli.py
tools/tom_hook_test.txt

