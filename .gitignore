COUNCIL_ARCHITECTURE.md
tools/autopilot.py
tools/tom_hook.py
tools/decomp_loop.py
tools/self_healer.py
# Council pipeline — compilation-verified iterative refinement modules
tools/build_validator.py
tools/iterative_refiner.py
tools/council_learning.py
